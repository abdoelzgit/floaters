datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                BigInt    @id @default(autoincrement())
  name              String    @db.VarChar(255)
  email             String    @unique @db.VarChar(255)
  email_verified_at DateTime? @db.Timestamp(6)
  password          String    @db.VarChar(255)
  role              UserRole  @default(customer)
  remember_token    String?   @db.VarChar(100)
  created_at        DateTime? @db.Timestamp(6)
  updated_at        DateTime? @db.Timestamp(6)
  bookings          Booking[]

  @@map("users")
}

enum UserRole {
  admin
  staff
  customer
  manager
}

model Airport {
  id               BigInt    @id @default(autoincrement())
  name             String    @db.VarChar(255)
  city             String    @db.VarChar(255)
  country          String    @db.VarChar(255)
  iata_code        String    @db.VarChar(5) @map("iata_code")
  created_at       DateTime? @db.Timestamp(6)
  updated_at       DateTime? @db.Timestamp(6)
  departureFlights Flight[]  @relation("DepartureAirport")
  arrivalFlights   Flight[]  @relation("ArrivalAirport")

  @@map("airports")
}

model Airline {
  id          BigInt     @id @default(autoincrement())
  name        String     @db.VarChar(255)
  code        String     @db.VarChar(10)
  logo        String?    @db.VarChar(255)
  description String?    @db.Text
  photos      String?    @db.VarChar(255)
  created_at  DateTime?  @db.Timestamp(6)
  updated_at  DateTime?  @db.Timestamp(6)
  airplanes   Airplane[]
  flights     Flight[]

  @@map("airlines")
}

model Airplane {
  id                  BigInt    @id @default(autoincrement())
  airline_id          BigInt
  model               String    @db.VarChar(255)
  registration_number String    @db.VarChar(255) @map("registration_number")
  capacity            Int
  description         String?   @db.Text
  photos              String?   @db.VarChar(255)
  created_at          DateTime? @db.Timestamp(6)
  updated_at          DateTime? @db.Timestamp(6)
  airline             Airline   @relation(fields: [airline_id], references: [id], onDelete: Cascade)
  seats               Seat[]
  flights             Flight[]

  @@map("airplanes")
}

model Seat {
  id          BigInt    @id @default(autoincrement())
  airplane_id BigInt
  seat_number String    @db.VarChar(255) @map("seat_number")
  class       SeatClass
  created_at  DateTime? @db.Timestamp(6)
  updated_at  DateTime? @db.Timestamp(6)
  airplane    Airplane  @relation(fields: [airplane_id], references: [id], onDelete: Cascade)

  @@map("seats")
}

enum SeatClass {
  economy
  business
  first
}

model Flight {
  id                   BigInt    @id @default(autoincrement())
  airline_id           BigInt
  airplane_id          BigInt
  departure_airport_id BigInt
  arrival_airport_id   BigInt
  flight_number        String    @db.VarChar(255) @map("flight_number")
  departure_time       DateTime  @map("departure_time")
  arrival_time         DateTime  @map("arrival_time")
  price                Decimal   @db.Decimal(12, 2)
  available_seats      Int       @map("available_seats")
  created_at           DateTime? @db.Timestamp(6)
  updated_at           DateTime? @db.Timestamp(6)

  airline          Airline   @relation(fields: [airline_id], references: [id], onDelete: Cascade)
  airplane         Airplane  @relation(fields: [airplane_id], references: [id], onDelete: Cascade)
  departureAirport Airport   @relation("DepartureAirport", fields: [departure_airport_id], references: [id], onDelete: Cascade)
  arrivalAirport   Airport   @relation("ArrivalAirport", fields: [arrival_airport_id], references: [id], onDelete: Cascade)
  bookings         Booking[]

  @@map("flights")
}

model Booking {
  id               BigInt        @id @default(autoincrement())
  user_id          BigInt
  flight_id        BigInt
  booking_code     String        @db.VarChar(255) @map("booking_code")
  total_passengers Int           @map("total_passengers")
  total_price      Decimal       @db.Decimal(12, 2) @map("total_price")
  status           BookingStatus @default(pending)
  created_at       DateTime?     @db.Timestamp(6)
  updated_at       DateTime?     @db.Timestamp(6)

  user       User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  flight     Flight      @relation(fields: [flight_id], references: [id], onDelete: Cascade)
  passengers Passenger[]
  payments   Payment[]

  @@map("bookings")
}

enum BookingStatus {
  pending
  confirmed
  cancelled
}

model Passenger {
  id              BigInt          @id @default(autoincrement())
  booking_id      BigInt
  full_name       String          @db.VarChar(255) @map("full_name")
  gender          PassengerGender
  birth_date      DateTime        @db.Date @map("birth_date")
  passport_number String          @db.VarChar(255) @map("passport_number")
  seat_number     String          @db.VarChar(255) @map("seat_number")
  created_at      DateTime?       @db.Timestamp(6)
  updated_at      DateTime?       @db.Timestamp(6)
  booking         Booking         @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@map("passengers")
}

enum PassengerGender {
  male
  female
}

model Payment {
  id               BigInt        @id @default(autoincrement())
  booking_id       BigInt
  payment_method   String        @db.VarChar(255) @map("payment_method")
  amount           Decimal       @db.Decimal(12, 2)
  payment_status   PaymentStatus @default(pending) @map("payment_status")
  transaction_code String        @db.VarChar(255) @map("transaction_code")
  created_at       DateTime?     @db.Timestamp(6)
  updated_at       DateTime?     @db.Timestamp(6)
  booking          Booking       @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@map("payments")
}

enum PaymentStatus {
  pending
  paid
  failed
}
